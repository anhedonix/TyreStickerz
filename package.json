{
  "name": "TyreStickerz",
  "version": "0.1.19",
  "private": true,
  "variables": {
    "primaryColor": "#ff4400",
    "secondaryColor": "#ff2200"
  },
  "engines": {
    "node": "14.4.x",
    "npm": "6.14.x"
  },
  "cacheDirectories": [
    ".next/cache"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p $PORT",
    "start_local": "next start",
    "storybook": "start-storybook -p 9009 -s public --ci",
    "flow": "flow",
    "log": "emacs -u $(id -un) --batch --eval '(load user-init-file)' logs.org -f org-latex-export-to-pdf",
    "build-storybook": "build-storybook",
    "node:refresh": "rm -rf node_modules package-lock.json && npm i",
    "heroku-postbuild": "npm run build"
  },
  "dependencies": {
    "@date-io/moment": "^1.3.13",
    "@material-ui/core": "^4.11.0",
    "@material-ui/icons": "^4.9.1",
    "@material-ui/lab": "^4.0.0-alpha.56",
    "@material-ui/pickers": "^3.2.10",
    "@types/browserify": "^12.0.36",
    "axios": "^0.19.2",
    "dom-css": "^2.1.0",
    "dotenv": "^8.2.0",
    "drei": "^1.5.1",
    "firebase": "^7.19.1",
    "lodash": "^4.17.20",
    "lorem-ipsum": "^2.0.3",
    "moment": "^2.27.0",
    "next": "^11.1.0",
    "next-transpile-modules": "^4.1.0",
    "pako": "^1.0.11",
    "postprocessing": "^6.17.3",
    "prop-types": "^15.7.2",
    "react": "16.13.1",
    "react-copy-to-clipboard": "^5.0.2",
    "react-custom-scrollbars": "^4.2.1",
    "react-dom": "16.13.1",
    "react-icons": "^3.11.0",
    "react-moment": "^0.9.7",
    "react-router-dom": "^5.2.0",
    "react-spring": "^8.0.27",
    "react-swipeable-views": "^0.13.9",
    "react-three-fiber": "^4.2.21",
    "react-touch": "^0.4.4",
    "three": "^0.119.1",
    "typeface-roboto": "^0.0.75",
    "uuid": "^8.3.0",
    "validate.js": "^0.13.1",
    "webpack": "^4.44.1"
  },
  "devDependencies": {
    "@babel/core": "^7.11.6",
    "@storybook/addon-actions": "^5.3.21",
    "@storybook/addon-links": "^5.3.21",
    "@storybook/addons": "^5.3.21",
    "@storybook/react": "^5.3.21",
    "babel-eslint": "^10.1.0",
    "babel-loader": "^8.1.0",
    "eslint": "^7.8.1",
    "eslint-config-airbnb": "^18.2.0",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-jsx-a11y": "^6.3.1",
    "eslint-plugin-react": "^7.20.6",
    "eslint-plugin-react-hooks": "^4.1.0",
    "gh-pages": "^3.1.0",
    "husky": "^4.3.0",
    "import-js": "^4.0.2",
    "javascript-typescript-langserver": "^2.11.3",
    "lint-staged": "^10.3.0",
    "prettier": "^2.1.1",
    "tern": "^0.24.3",
    "typescript": "^3.9.7",
    "typescript-language-server": "^0.4.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,sass,md}": [
      "./node_modules/.bin/prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
